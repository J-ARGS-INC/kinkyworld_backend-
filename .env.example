# Copy this to .env and fill in your values — NEVER commit .env to git

# ── Database (Supabase PostgreSQL) ────────────────────────
DB_HOST=aws-0-eu-west-3.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.YOUR_PROJECT_REF
DB_PASSWORD=YOUR_DB_PASSWORD

# ── Security ───────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=78fb11fe6e5841bc85a7fa55e646e3ea4c0b278fb8ab5146fd0007ab52519c58

# Admin key — the only credential needed to access the admin panel
# Generate: python -c "import secrets; print(secrets.token_urlsafe(24))"
ADMIN_KEY=4ifYcqsO26dSWwoC16l3Ydc-YUM4ZWcp

# Admin account seeded on first startup
ADMIN_EMAIL=admin@kinkyworld.com
ADMIN_PASSWORD=change-this-strong-password

# ── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
FRONTEND_URL=https://kinkyworlddungeonshotels.com,https://www.kinkyworlddungeonshotels.com,http://localhost:5173

# ── Port ───────────────────────────────────────────────────
PORT=5000

# ── File Uploads ───────────────────────────────────────────
# Absolute path to store uploaded images (use Render Disk mount path in prod)
UPLOAD_DIR=/var/data/uploads
